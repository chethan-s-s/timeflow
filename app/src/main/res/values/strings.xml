    <!-- Legal — marked non-translatable so lint doesn't require ES copies -->
    <string name="privacy_policy_content" translatable="false">
        Privacy Policy – Time Flow\n\nLast updated: April 9, 2026\n\n
        Time Flow ("the App") is developed by Chethan S ("Developer").\n\n
        1. Data We Collect\n
        Time Flow stores all your countdown data locally on your device using a Room (SQLite) database. We do not collect, transmit, or share any personal data with third parties.\n\n
        2. Notifications\n
        The App requests the POST_NOTIFICATIONS permission solely to notify you when a countdown you created has finished. No notification data leaves your device.\n\n
        3. Alarms\n
        The App uses SCHEDULE_EXACT_ALARM / USE_EXACT_ALARM to fire notifications precisely at your chosen countdown time. This data is processed entirely on-device.\n\n
        4. Images\n
        Photos you add to countdowns are stored in the App\'s private internal storage and are never uploaded or shared.\n\n
        5. Analytics / Advertising\n
        The App contains no analytics SDKs, advertising SDKs, or tracking of any kind.\n\n
        6. Children\n
        The App does not knowingly collect data from children under 13.\n\n
        7. Contact\n
        Questions? Email: support@timeflow.app
    </string>
    <string name="terms_of_service_content" translatable="false">
        Terms of Service – Time Flow\n\nLast updated: April 9, 2026\n\n
        By using Time Flow you agree to the following terms:\n\n
        1. Use\n
        You may use the App for personal, non-commercial purposes. Do not reverse-engineer, decompile, or redistribute the App.\n\n
        2. No Warranty\n
        The App is provided "as is" without warranty of any kind. The Developer is not responsible for missed events caused by device restrictions on alarms or notifications.\n\n
        3. Changes\n
        These terms may be updated at any time. Continued use of the App constitutes acceptance of any updated terms.\n\n
        4. Contact\n
        support@timeflow.app
    </string>
    <string name="about_developer_content" translatable="false">
        Time Flow is built by Chethan S – a solo developer passionate about clean, minimal apps.\n\n
        Version 1.0\n
        Contact: support@timeflow.app\n\n
        Thank you for using Time Flow! ❤️
    </string>

